  "keyFeatures": [
    "ANTLR4-based lexer and parser for custom language syntax",
    "Visitor pattern implementation for AST traversal and execution",
    "Support for integer variables, arithmetic, and relational operations",
    "If-else conditional statements with block scoping",
    "Runtime memory management and variable tracking",
    "Syntax error detection and validation"
  ],
  "publicApiSurface": [
    "Visitor class - Main interpreter with memory management",
    "ExpresionesLexer - Tokenizes source code",
    "ExpresionesParser - Parses tokens into AST",
    "Prueba.py - Main entry point for executing programs",
    "visitProg() - Entry point for program execution",
    "visitAritmetica() - Handles arithmetic operations",
    "visitRelacional() - Evaluates relational expressions",
    "visitInstrIf() - Executes if-else statements"
  ]
